      "type": "section",
      "label": "Deploy static content to Pages",
      "properties": {
        "kind": "workflow",
        "filePath": ".github/workflows/static.yml",
        "trigger": "push to main branch or manual dispatch",
        "permissions": ["contents:read", "pages:write", "id-token:write"],
        "concurrency": "pages (no cancel-in-progress)"
      }
    },
    {
      "id": "job:::static.yml::build",
      "type": "section",
      "label": "build",
      "properties": {
        "kind": "job",
        "filePath": ".github/workflows/static.yml",
        "runner": "ubuntu-latest",
        "steps": [
          "actions/checkout@v6",
          "actions/setup-node@v6 (node 24)",
          "npm install",
          "npm run build",
          "actions/upload-pages-artifact@v5 (./dist)"
        ]
      }
    },
    {
      "id": "job:::static.yml::deploy",
      "type": "section",
      "label": "deploy",
      "properties": {
        "kind": "job",
        "filePath": ".github/workflows/static.yml",
        "runner": "ubuntu-latest",
        "dependsOn": "build",
        "environment": "github-pages",
        "steps": [
          "actions/deploy-pages@v5"
        ]
      }
    }
